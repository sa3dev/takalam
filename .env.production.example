# ===========================================
# .env.production.example
# Copiez ce fichier dans Dokploy > Environment Variables
# NE PAS committer les vraies valeurs dans git
# ===========================================

# ===========================================
# BASE DE DONNÉES
# ===========================================
POSTGRES_DB=takalam
POSTGRES_USER=takalam_user
POSTGRES_PASSWORD=                      # Générer : openssl rand -hex 24

# ===========================================
# SÉCURITÉ — obligatoires, pas de défaut
# ===========================================
SECRET_KEY=                             # Générer : openssl rand -hex 32
JWT_SECRET=                             # Générer : openssl rand -hex 32

# ===========================================
# CLÉS API IA
# ===========================================
# Groq — LLM (Llama 3.3 70B) + STT (Whisper Large v3) ← principal, obligatoire
GROQ_API_KEY=gsk_...

# OpenAI — optionnel (non utilisé, Edge TTS est gratuit et sans clé)
# OPENAI_API_KEY=sk-...

# ElevenLabs — TTS alternatif (optionnel)
# ELEVENLABS_API_KEY=

# ===========================================
# URLS PUBLIQUES (remplacer par ton domaine)
# ===========================================
NEXT_PUBLIC_API_URL=https://api.takalam.ton-domaine.com
NEXT_PUBLIC_WS_URL=wss://api.takalam.ton-domaine.com
NEXT_PUBLIC_DOMAIN=takalam.ton-domaine.com

# Origines autorisées pour le CORS (virgule-séparées)
ALLOWED_ORIGINS=https://takalam.ton-domaine.com

# ===========================================
# PROXY INTERNE DOCKER (ne pas modifier)
# ===========================================
INTERNAL_API_URL=http://backend:8000
