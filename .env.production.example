# ===========================================
# .env.production.example
# Copiez ce fichier dans Dokploy > Environment Variables
# NE PAS committer les vraies valeurs dans git
# ===========================================

# ===========================================
# BASE DE DONNÉES
# ===========================================
POSTGRES_DB=takalam
POSTGRES_USER=takalam_user
POSTGRES_PASSWORD=                      # Générer : openssl rand -hex 24

# ===========================================
# SÉCURITÉ
# ===========================================
SECRET_KEY=                             # Générer : openssl rand -hex 32
JWT_SECRET=                             # Générer : openssl rand -hex 32

# ===========================================
# CLÉS API IA
# ===========================================
# Groq — LLM (Llama 3.3 70B) + STT (Whisper Large v3) ← principal
GROQ_API_KEY=gsk_...

# OpenAI — TTS uniquement (fallback optionnel)
OPENAI_API_KEY=sk-...

# ElevenLabs — TTS voix arabe
ELEVENLABS_API_KEY=...

# ===========================================
# URLS PUBLIQUES (remplacer par ton domaine)
# ===========================================
NEXT_PUBLIC_API_URL=https://api.takalam.ton-domaine.com
NEXT_PUBLIC_WS_URL=wss://api.takalam.ton-domaine.com
NEXT_PUBLIC_DOMAIN=takalam.ton-domaine.com
